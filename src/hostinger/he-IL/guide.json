    },
    "dns": {
      "instructions": [
        "עבור לסעיף 'דומיינים'",
        "מצא את הדומיין שלך ולחץ על 'ניהול'",
        "נווט ל'עורך אזור DNS'",
        "לחץ על 'הוסף רשומה'",
        "בחר את סוג הרשומה מרשימת התפריט הנפתח",
        "מלא את שדות 'שם' ו'מצביע ל' באמצעות הערכים מהטבלה למטה",
        "שמור על ערך TTL ברירת המחדל של 14400",
        "לחץ על 'הוסף רשומה' לשמירה"
      ],
      "visual": {
        "type": "image",
        "src": "dns.png"
      }
    }
  }
}
